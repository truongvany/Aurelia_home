{
  "name": "kingman-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "seed": "tsx src/seed/seed.ts",
    "seed:fashion-menu": "tsx src/seed/seed-fashion-menu.ts",
    "seed:shirts": "tsx src/seed/seed-shirts.ts",
    "seed:users": "tsx src/seed/seed-users.ts",
    "seed:categories": "tsx src/seed/seed-categories.ts",
    "seed:products": "tsx src/seed/seed-products.ts",
    "seed:all": "npm run seed:users && npm run seed:categories && npm run seed:products"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "groq-sdk": "^0.5.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
